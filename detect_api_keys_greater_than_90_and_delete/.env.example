# Endor Labs API credentials
# Copy this file to .env and fill in your values.

# API key and secret generated from the Endor Labs UI
# (Settings > Access Control > API Keys). The key needs permissions to
# READ and DELETE API keys in every namespace it should manage.
API_KEY=endr+your_key_here
API_SECRET=endr+your_secret_here

# Root tenant namespace (e.g. "my-company"). Child namespaces are traversed
# automatically.
ENDOR_NAMESPACE=your-namespace-here

# Optional override for non-production tenants.
# ENDOR_API_BASE_URL=https://api.endorlabs.com
