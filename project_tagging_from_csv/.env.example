# ── Authentication ──────────────────────────────────────────────────
# Option 1 (recommended): Use endorctl to generate a short-lived token.
#   export ENDOR_TOKEN="$(endorctl auth --print-access-token)"
#
# Option 2: Provide an API key and secret (created in Endor Labs UI).
# API_KEY=endr+xxxxxxxxxxxx
# API_SECRET=endr+xxxxxxxxxxxx

# ── Namespace & Git Org ────────────────────────────────────────────
# These can also be passed as CLI flags: --namespace / --gitorg
# ENDOR_NAMESPACE=my-company.gh-my-org
# GITORG=my-org
